@model Laboratorio05.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1>Eliminar Producto</h1>

<h3>¿Está seguro de que desea eliminar este producto?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>
        
        <dt class="col-sm-3">Precio</dt>
        <dd class="col-sm-9">@Model.Precio.ToString("C")</dd>
        
        <dt class="col-sm-3">Categoría</dt>
        <dd class="col-sm-9">@Model.Categoria</dd>
        
        <dt class="col-sm-3">Fecha de Ingreso</dt>
        <dd class="col-sm-9">@Model.FechaIngreso.ToString("dd/MM/yyyy")</dd>
        
        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">@(Model.Activo ? "Activo" : "Inactivo")</dd>
    </dl>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
